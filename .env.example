# 이 파일은 "이름표 예시"입니다. (실제 비밀값은 여기 적지 않아요)
# 사용법:
#   1) 이 파일을 복사해서 이름을 ".env" 로 바꾸세요.
#   2) .env 파일 안에 = 뒤에 실제 값을 채워 넣으세요.
#   3) .env 는 .gitignore 덕분에 깃허브에 올라가지 않습니다.

# Claude API 키 (console.anthropic.com 에서 발급, sk-ant- 로 시작)
ANTHROPIC_API_KEY=

# 노션 연동(Integration) 토큰 (ntn_ 또는 secret_ 로 시작)
NOTION_TOKEN=

# 브리핑이 들어갈 "증시 브리핑" 노션 페이지의 ID (32자리)
NOTION_PARENT_PAGE_ID=3841aeb75d2380a5866bd4ff68c514ae
